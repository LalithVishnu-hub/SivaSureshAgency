rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== IMPORTANT =====
    // These rules must be published to Firebase Console:
    // 1. Go to Firebase Console → Firestore → Rules
    // 2. Copy-paste these rules
    // 3. Click "Publish"
    // Without publishing, the defaults will block access.

    // Products & Inventory: public reads, any auth writes
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /inventory/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: anyone (including anon) can CREATE or READ
    // Authenticated users (admin) can update/delete
    match /orders/{id} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }

    // Customers: 
    // - Anyone can CREATE (customer registration)
    // - Authenticated users (admin) can READ all
    // - Anyone can UPDATE their record
    // - Only authenticated users can DELETE
    match /customers/{id} {
      allow create, update: if true;
      allow read: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}

