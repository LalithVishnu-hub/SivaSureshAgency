rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Products & Inventory: public reads, admin-only writes
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /inventory/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: anyone can CREATE (customer checkout); only admin can read/update/delete
    match /orders/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Customers: anyone can CREATE (registration/checkout); only admin can read/update/delete
    match /customers/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}

