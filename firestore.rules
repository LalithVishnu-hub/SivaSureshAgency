rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Products & Inventory: public reads, admin-only writes
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /inventory/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: anyone can CREATE (customer checkout) or READ (customer status check)
    // Only authenticated users (admin) can update/delete
    match /orders/{id} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }

    // Customers: anyone can CREATE/UPDATE own record; only admin can read all or delete
    match /customers/{id} {
      allow create, update: if true;
      allow read, delete: if request.auth != null;
    }
  }
}

